{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "2.0.0" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "iteration": 1700000000000,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "CPU (JVM) %",
      "id": 1,
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "avg(jvm_cpu_recent_utilization_ratio{job=\"$job\", instance=\"$inst\"}) * 100",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 }
    },
    {
      "type": "stat",
      "title": "Heap Used %",
      "id": 2,
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "100 * sum(jvm_memory_used_bytes{job=\"$job\", instance=\"$inst\", jvm_memory_type=\"heap\"}) / sum(jvm_memory_committed_bytes{job=\"$job\", instance=\"$inst\", jvm_memory_type=\"heap\"})",
          "legendFormat": "Heap %",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 },
        "overrides": []
      },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "GC rate /s (minor vs major)",
      "id": 3,
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum by (jvm_gc_action) (rate(jvm_gc_duration_seconds_count{job=\"$job\", instance=\"$inst\"}[5m]))",
          "legendFormat": "{{jvm_gc_action}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "options": { "legend": { "showLegend": true }, "tooltip": { "mode": "single" } }
    },
    {
      "type": "timeseries",
      "title": "GC p95 duration (s)",
      "id": 4,
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, jvm_gc_action) (rate(jvm_gc_duration_seconds_bucket{job=\"$job\", instance=\"$inst\"}[5m])))",
          "legendFormat": "p95 {{jvm_gc_action}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "options": { "legend": { "showLegend": true }, "tooltip": { "mode": "single" } }
    },
    {
      "type": "timeseries",
      "title": "Threads by state",
      "id": 5,
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum by (jvm_thread_state) (jvm_thread_count{job=\"$job\", instance=\"$inst\"})",
          "legendFormat": "{{jvm_thread_state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "options": { "legend": { "showLegend": true }, "tooltip": { "mode": "single" } }
    },
    {
      "type": "timeseries",
      "title": "Classes loaded",
      "id": 6,
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(jvm_class_count{job=\"$job\", instance=\"$inst\"})",
          "legendFormat": "loaded classes",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "options": { "legend": { "showLegend": false }, "tooltip": { "mode": "single" } }
    },
    {
      "type": "timeseries",
      "title": "OTLP export success rate (%)",
      "id": 7,
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "100 * sum(increase(otlp_exporter_exported_total{job=\"$job\", instance=\"$inst\", success=\"true\"}[5m])) / clamp_min(sum(increase(otlp_exporter_seen_total{job=\"$job\", instance=\"$inst\"}[5m])), 1)",
          "legendFormat": "success %",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "options": { "legend": { "showLegend": false }, "tooltip": { "mode": "single" } }
    },
    {
      "type": "timeseries",
      "title": "OTLP failures (5m)",
      "id": 8,
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(increase(otlp_exporter_exported_total{job=\"$job\", instance=\"$inst\", success=\"false\"}[5m]))",
          "legendFormat": "failures",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "options": { "legend": { "showLegend": false }, "tooltip": { "mode": "single" } }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 37,
  "style": "dark",
  "tags": ["otel", "java", "jvm", "tomcat"],
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "job",
        "label": "Job (service)",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(jvm_cpu_count, job)",
        "includeAll": false,
        "multi": false,
        "refresh": 2,
        "hide": 0,
        "options": []
      },
      {
        "type": "query",
        "name": "inst",
        "label": "Instance",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(jvm_cpu_count{job=\"$job\"}, instance)",
        "includeAll": false,
        "multi": false,
        "refresh": 2,
        "hide": 0,
        "options": []
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": { "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"] },
  "timezone": "",
  "title": "OTel Java (Tomcat) — JVM Overview",
  "uid": null,
  "version": 1,
  "weekStart": ""
}
